<Page x:Class="AdvokatOffice.Views.UserMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная - Пользователь" Width="1000" Height="700">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryColor}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="🏛️ Адвокатская контора" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Ваш надежный юридический партнер" Foreground="#BDC3C7" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="14" HorizontalAlignment="Right" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,10">
            <TabItem Header="📋 Услуги">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgServices" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="80"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <Button Content="💳 Оплатить услугу" Click="Pay_Click" Style="{StaticResource SuccessButton}" Width="150"/>
                        <Button Content="📦 Мои заказы" Click="MyOrders_Click" Width="150"/>
                        <Button Content="🚪 Выход" Click="Logout_Click" Style="{StaticResource DangerButton}" Width="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="ℹ️ О нас">
                <Border Style="{StaticResource Card}" Margin="20">
                    <StackPanel>
                        <TextBlock Text="О нашей компании" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,10">
                            Адвокатская контора "Правовая защита" работает на рынке юридических услуг более 15 лет.
                            Наша команда состоит из высококвалифицированных адвокатов с богатым опытом работы в различных отраслях права.
                        </TextBlock>
                        <TextBlock Text="Наши преимущества:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <TextBlock Text="✓ Индивидуальный подход к каждому клиенту" Margin="10,2"/>
                        <TextBlock Text="✓ Прозрачная система оплаты" Margin="10,2"/>
                        <TextBlock Text="✓ Конфиденциальность информации" Margin="10,2"/>
                        <TextBlock Text="✓ Работа по всей стране" Margin="10,2"/>
                        <TextBlock Text="✓ Первая консультация - бесплатно" Margin="10,2"/>

                        <TextBlock Text="Контакты:" FontWeight="Bold" Margin="0,20,0,5"/>
                        <TextBlock Text="📍 Адрес: г. Казань, ул. Татарстан, д. 10, офис 5" Margin="10,2"/>
                        <TextBlock Text="📞 Телефон: +7 (999) 999-99-01" Margin="10,2"/>
                        <TextBlock Text="✉️ Email: info@advokat.ru" Margin="10,2"/>
                        <TextBlock Text="⏰ Режим работы: Пн-Пт 9:00 - 20:00, Сб 10:00 - 16:00" Margin="10,2"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Page>