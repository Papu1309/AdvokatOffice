<Page x:Class="AdvokatOffice.Views.AdminMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель администратора" Width="1400" Height="800" 
      >
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryColor}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="👨‍💼 Панель администратора" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Управление услугами, заказами и пользователями" Foreground="#BDC3C7" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="0,10" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="📋 Услуги">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить" Click="Add_Click" Style="{StaticResource SuccessButton}" Width="130"/>
                        <Button Content="✏ Редактировать" Click="Edit_Click" Width="150"/>
                        <Button Content="🗑 Удалить" Click="Delete_Click" Style="{StaticResource DangerButton}" Width="130"/>
                    </StackPanel>

                    <DataGrid x:Name="dgServices" Grid.Row="1" AutoGenerateColumns="False" 
                              ScrollViewer.CanContentScroll="True" VirtualizingStackPanel.IsVirtualizing="True"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="400"/>
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration}" Width="120"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="🚪 Выход" Click="Logout_Click" Style="{StaticResource DangerButton}" Width="100" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="📦 Заказы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="💾 Сохранить изменения" Click="SaveOrders_Click" Style="{StaticResource SuccessButton}" Width="200"/>
                        <Button Content="🔄 Обновить" Click="RefreshOrders_Click" Width="140"/>
                    </StackPanel>

                    <DataGrid x:Name="dgOrders" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                              ScrollViewer.CanContentScroll="True" VirtualizingStackPanel.IsVirtualizing="True"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              RowHeight="45" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding Users.Login}" Width="120"/>
                            <DataGridTextColumn Header="Услуга" Binding="{Binding Services.Name}" Width="180"/>
                            <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Services.Price, StringFormat=C}" Width="90"/>
                            <DataGridTextColumn Header="Способ оплаты" Binding="{Binding PaymentMethod}" Width="100"/>
                            <DataGridTemplateColumn Header="Статус" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Name="StatusComboBox" 
                                                  SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag"
                                                  Height="32" Width="110"
                                                  Background="White"
                                                  Loaded="ComboBox_Loaded">
                                            <ComboBoxItem Content="🟡 Ожидает" Tag="Ожидает" IsSelected="True"/>
                                            <ComboBoxItem Content="✅ Выполнен" Tag="Выполнен"/>
                                            <ComboBoxItem Content="❌ Отменён" Tag="Отменён"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Адрес получения" Binding="{Binding PickupAddress}" Width="200"/>
                            <DataGridTextColumn Header="Время получения" Binding="{Binding PickupTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="👥 Пользователи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="➕ Добавить пользователя" Click="AddUser_Click" Style="{StaticResource SuccessButton}" Width="220" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgUsers" Grid.Row="1" AutoGenerateColumns="False" 
                              ScrollViewer.CanContentScroll="True" VirtualizingStackPanel.IsVirtualizing="True"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="130"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="170"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Roles.Name}" Width="110"/>
                            <DataGridTemplateColumn Header="Действия" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑 Удалить" Tag="{Binding}" Click="DeleteUser_Click" 
                                                Width="85" Height="32" Margin="2" 
                                                Style="{StaticResource DangerButton}" FontSize="12"
                                                HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>