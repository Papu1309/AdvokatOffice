<Page x:Class="AdvokatOffice.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход в систему" Width="450" Height="500">
    <Grid VerticalAlignment="Center">
        <Border Style="{StaticResource Card}" Width="400">
            <StackPanel>
                <TextBlock Text="🏛️ Адвокатская контора" Style="{StaticResource PageTitle}" FontSize="20" Margin="0,0,0,10"/>
                <TextBlock Text="Вход в систему" Style="{StaticResource SubTitle}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" FontSize="14"/>

                <TextBlock Text="Пароль" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtPassword" FontSize="14"/>

                <Button Content="Войти" Click="Login_Click" Height="40" Margin="0,20,0,10" Style="{StaticResource SuccessButton}"/>
                <Button Content="Регистрация" Click="Register_Click" Height="40" Background="#95A5A6" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>