<Window x:Class="AdvokatOffice.Views.ServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование услуги" Height="604" Width="500" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="8" Padding="20">
        <StackPanel>
            <TextBlock Text="📝 Данные услуги" Style="{StaticResource PageTitle}" FontSize="18"/>

            <TextBlock Text="Название *" Margin="0,10,0,5"/>
            <TextBox x:Name="txtName"/>

            <TextBlock Text="Описание" Margin="0,10,0,5"/>
            <TextBox x:Name="txtDescription" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>

            <TextBlock Text="Длительность (мин) *" Margin="0,10,0,5"/>
            <TextBox x:Name="txtDuration"/>
            <TextBlock Text="Пример: 60" FontSize="11" Foreground="Gray" Margin="0,-5,0,5"/>

            <TextBlock Text="Цена (руб) *" Margin="0,10,0,5"/>
            <TextBox x:Name="txtPrice"/>
            <TextBlock Text="Пример: 3000" FontSize="11" Foreground="Gray" Margin="0,-5,0,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="💾 Сохранить" Click="Ok_Click" Width="124" Style="{StaticResource SuccessButton}"/>
                <Button Content="❌ Отмена" Click="Cancel_Click" Width="124" Background="#95A5A6" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>