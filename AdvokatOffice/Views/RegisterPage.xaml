<Page x:Class="AdvokatOffice.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация" Width="500" Height="650">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Center">
            <Border Style="{StaticResource Card}" Width="450">
                <StackPanel>
                    <TextBlock Text="📝 Регистрация нового клиента" Style="{StaticResource PageTitle}" FontSize="20" Margin="0,0,0,10"/>

                    <TextBlock Text="Логин *" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtLogin"/>

                    <TextBlock Text="Пароль *" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtPassword"/>

                    <TextBlock Text="Подтверждение пароля *" Margin="0,10,0,5"/>
                    <PasswordBox x:Name="txtConfirmPassword"/>

                    <TextBlock Text="ФИО" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtFullName"/>

                    <TextBlock Text="Телефон" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtPhone"/>

                    <TextBlock Text="Email" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtEmail"/>

                    <Button Content="Зарегистрироваться" Click="Register_Click" Height="40" Margin="0,20,0,10" Style="{StaticResource SuccessButton}"/>
                    <Button Content="Назад" Click="Back_Click" Height="40" Background="#95A5A6" Foreground="White"/>

                    <TextBlock Text="* - обязательные поля" FontSize="11" Foreground="#7F8C8D" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>